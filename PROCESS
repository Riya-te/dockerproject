## 🔹 🔄 Jenkins Pipeline (CI/CD)

```groovy
pipeline {
    agent any

    triggers {
        githubPush()
    }

    stages {
        stage('checkout') {
            steps {
                git 'https://github.com/YOUR-REPO.git'
            }
        }
        stage('build') {
            steps {
                sh 'docker build -t $image .'
            }
        }
        stage('tag') {
            steps {
                sh 'docker tag $image $repo'
            }
        }
        stage('push') {
            steps {
                sh 'docker login -u <user> -p $password'
                sh 'docker push $repo'
            }
        }
        stage('deploy') {
            steps {
                sh 'docker stack deploy -c docker-compose.yml bank'
            }
        }
    }
}
```

