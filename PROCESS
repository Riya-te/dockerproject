## 🔹 📦 Docker Compose (With Nginx)

```yaml
version: '3.8'

services:

  nginx:
    image: nginx:latest
    ports:
      - "80:80"
    configs:
      - source: nginx_conf
        target: /etc/nginx/nginx.conf
    networks:
      - banknet

  internetbanking:
    image: yourrepo/ib:latest
    networks:
      - banknet
    deploy:
      replicas: 3

  mobilebanking:
    image: yourrepo/mb:latest
    networks:
      - banknet
    deploy:
      replicas: 3

  insurance:
    image: yourrepo/insurance:latest
    networks:
      - banknet
    deploy:
      replicas: 3

  loan:
    image: yourrepo/loan:latest
    networks:
      - banknet
    deploy:
      replicas: 3

networks:
  banknet:
    driver: overlay

configs:
  nginx_conf:
    external: true
```

---

## 🔹 🌐 Nginx Configuration

```nginx
events {}

http {
    resolver 127.0.0.11;

    server {
        listen 80;

        location /internet/ {
            proxy_pass http://internetbanking/;
        }
        location /mobile/ {
            proxy_pass http://mobilebanking/;
        }
        location /insurance/ {
            proxy_pass http://insurance/;
        }
        location /loan/ {
            proxy_pass http://loan/;
        }
    }
}
```

